{
  "name": "chrome-extension-testing",
  "version": "0.1.0",
  "description": "Testing utilities for Chrome extensions — realistic chrome.* API mocks for Jest, custom matchers, and test helpers. The missing testing library for extension developers.",
  "author": "Zovo <hello@zovo.one>",
  "license": "MIT",
  "keywords": [
    "chrome-extension",
    "testing",
    "jest",
    "mock",
    "chrome-api",
    "unit-test",
    "content-script",
    "service-worker",
    "manifest-v3",
    "chrome-storage-mock",
    "chrome-tabs-mock",
    "browser-extension",
    "test-utils"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/theluckystrike/chrome-extension-testing.git"
  },
  "homepage": "https://github.com/theluckystrike/chrome-extension-testing",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "jest": ">=29.0.0"
  },
  "peerDependenciesMeta": {
    "jest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  }
}
